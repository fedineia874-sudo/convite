 <!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Convite Especial</title>
<style>
  body {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: #e0e8f5; /* fundo suave */
    font-family: 'Georgia', serif;
  }

  .envelope-container {
    width: 450px;
    height: 280px;
    perspective: 1000px;
    position: relative;
  }

  .envelope {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  /* Envelope luxuoso */
  .envelope::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: #8fbaf5;
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    z-index: 1;
  }

  /* Aba do envelope */
  .aba {
    position: absolute;
    top: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(135deg, #aad1ff, #639ff5);
    transform-origin: top;
    transition: transform 1s ease;
    z-index: 2;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  /* Convite dentro do envelope */
  .convite-placeholder {
    position: absolute;
    top: 55%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    height: auto;
    z-index: 0;
    pointer-events: none;
    border-radius: 8px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    background: rgba(255,255,255,0.2);
  }

  /* Flores 3D decorativas */
  .flores {
    position: absolute;
    width: 100%;
    height: 100%;
    background: url('flores-azuis-3d.png') no-repeat center/cover;
    z-index: 0;
    pointer-events: none;
    border-radius: 12px;
  }

  /* Aba aberta */
  .envelope.aberto .aba {
    transform: rotateX(-180deg);
  }
</style>
</head>
<body>

<div class="envelope-container">
  <div class="envelope" id="envelope">
    <div class="aba" onclick="abrirEnvelope()"></div>
    <!-- Este bloco pode ser substituído pelo seu convite em PDF ou imagem -->
    <div class="convite-placeholder"></div>
    <div class="flores"></div>
  </div>
</div>

<script>
function abrirEnvelope() {
  const env = document.getElementById('envelope');
  env.classList.toggle('aberto');

  // Abre o PDF do convite após 1 segundo (tempo da animação)
  setTimeout(() => {
    window.open('convite.pdf', '_blank');
  }, 1000);
}
</script>

</body>
</html>